# API Configuration
# For local development:
VITE_API_BASE_URL=http://localhost:8000/api

# For cPanel deployment:
# VITE_API_BASE_URL=https://your-cpanel-domain.com/api

# For Render/Vercel deployment:
# VITE_API_BASE_URL=https://supply-chain-backend-hwh6.onrender.com/api

# IMPORTANT: Always include /api at the end of the URL

# Optional: Environment
VITE_ENV=development

# Phase 7: Finance AP Cutover Date
# Set this to the ISO date when Finance AP routing begins
# MRFs created on or after this date use Finance AP; earlier MRFs use legacy internal finance
# Format: YYYY-MM-DD (e.g., 2025-03-01)
# Leave blank or unset to disable Finance AP routing (all MRFs use legacy internal finance)
VITE_FINANCE_AP_CUTOVER_DATE=
