# API Configuration
# For local development:
VITE_API_BASE_URL=http://localhost:8000/api

# For cPanel deployment:
# VITE_API_BASE_URL=https://your-cpanel-domain.com/api

# For Render/Vercel deployment:
# VITE_API_BASE_URL=https://supply-chain-backend-hwh6.onrender.com/api

# IMPORTANT: Always include /api at the end of the URL

# Optional: Environment
VITE_ENV=development

# Documents FINANCE_AP_CUTOVER_DATE on the server (source of truth).
# Optional dev mirror — must match supply-chain-backend FINANCE_AP_CUTOVER_DATE if set:
VITE_FINANCE_AP_CUTOVER_DATE=2026-06-01

# Optional: Finance AP vendor sync flag (server-side; documented for ops)
# FINANCE_AP_VENDOR_SYNC_ENABLED=true
